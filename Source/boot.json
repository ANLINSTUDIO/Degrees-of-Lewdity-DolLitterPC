{
    "name": "小小PC",
    "version": "1.1.0",
    "styleFileList": ["litterpc.css"],
    "scriptFileList": ["litterpc.js"],
    "tweeFileList": ["settings.twee"],
    "imgFileList": [],
    "addonPlugin": [
        {
            "modName": "TweeReplacer",
            "addonName": "TweeReplacerAddon",
            "modVersion": "^1.0.0",
            "params": [
                {
                    "passage": "overlayReplace",
                    "findRegex": "<<optionsinformation>><<\\/replace>>[\\s\\S]*?<<\\/button>>", 
                    "regexFlag": "g",  
                    "replace": "<<optionsinformation>><</replace>>\n\t\t<</button>><<litterpcModTab>>"
                }
            ]
        }
    ],
    "dependenceInfo": [
        {
            "modName": "ModLoader",
            "version": "^2.31.2"
        },
        {
            "modName": "TweeReplacer",
            "version": "^1.0.0"
        }
    ]
}